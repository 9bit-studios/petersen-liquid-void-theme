{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "Fresh Glass Theme - TypeScript Configuration",
  "_authority": "Quantum Spatial Workspace Base Configuration",
  "_purpose": "HIG-compliant design theme with Apple Design Language",

  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "declarationDir": "./dist/types",
    "noPropertyAccessFromIndexSignature": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@fresh-glass/*": ["./src/*"],
      "@/tokens/*": ["./tokens/*"],
      "@/theme/*": ["./theme/*"],
      "@/components/*": ["./components/*"],

      "@/design-system/*": ["../design-system/*"],
      "@/quantum-spatial/*": ["../design-system/*"],
      "@quantum-spatial/design-system/*": ["../design-system/*"],
      "@quantum-spatial/design-system/hooks": ["../design-system/hooks/index.ts"],
      "@quantum-spatial/design-system/tokens": ["../design-system/tokens"],
      "@quantum-spatial/design-system/tokens/*": ["../design-system/tokens/*"],

      "@/apple-intelligence/*": ["../../apple-intelligence/*"],
      "@/strategic-director/*": ["../../bridges/swift-typescript/generated/*"],
      "@/sources-of-truth/*": ["../../apple-intelligence/foundation/sources-of-truth/*"],
      "@/apple-hig/*": ["../../apple-intelligence/foundation/sources-of-truth/*"],
      "@/validation/*": ["../../validation/*"],
      "@/bridges/*": ["../../bridges/*"],
      "@/foundation-models/*": ["../../foundation-models/*"]
    }
  },

  "include": [
    "src/**/*",
    "tokens/**/*",
    "theme/**/*",
    "components/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "build",
    "*.test.ts",
    "*.spec.ts",
    "**/*.js",
    "petersen-*/**/*",
    "liquid-*/**/*"
  ]
}
